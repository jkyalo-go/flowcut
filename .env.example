# ── Core ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=dev

# ── Backend: auth & session ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-before-starting
SESSION_COOKIE_NAME=flowcut_session
SESSION_COOKIE_SECURE=false
REQUIRE_DB_MIGRATIONS=true

# ── Backend: URLs & CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
RENDER_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ── Backend: database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://flowcut:flowcut@localhost:5432/flowcut

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── AI providers (leave blank unless used) ────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
ALIBABA_DASHSCOPE_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
GCS_MEDIA_BUCKET=
GCS_MODELS_BUCKET=
GCS_SIGNED_URL_TTL_SECONDS=3600

# ── Billing: Stripe ───────────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Platform OAuth ────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=
